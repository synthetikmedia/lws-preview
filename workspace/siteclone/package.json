{
  "name": "siteclone",
  "version": "1.0.0",
  "description": "Clone websites into fully local static HTML with all assets",
  "main": "dist/clone.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/clone.js",
    "dev": "ts-node src/clone.ts",
    "clone": "ts-node src/clone.ts"
  },
  "bin": {
    "siteclone": "./dist/clone.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "playwright": "^1.50.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^22.10.7",
    "@types/xml2js": "^0.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
